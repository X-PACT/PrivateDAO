{
	email {$ACME_EMAIL}
}

(privatedao_primary_host) {
	root * /srv/privatedao/site
	encode gzip zstd

	header {
		X-PrivateDAO-Primary-Host "candidate"
		X-PrivateDAO-Backup-Policy "github-pages-backup-only"
	}

	@health path /healthz /api/health
	handle @health {
		reverse_proxy read-node:8787
	}

	@api path /api/v1 /api/v1/*
	handle @api {
		reverse_proxy read-node:8787
	}

	@quicknode_root {
		method POST
		path /
	}
	handle @quicknode_root {
		rewrite * /api/v1/quicknode/stream
		reverse_proxy read-node:8787
	}

	handle {
		@missing_page {
			not file {path} {path}/index.html
			not path /_next/* /assets/* /favicon.ico /manifest.webmanifest /robots.txt /sitemap.xml /llms.txt /ai.json /evidence.json /ownership.json /rights.txt /opengraph-image.png /twitter-image.png
		}
		redir @missing_page /thesis/ 302
		try_files {path} {path}/index.html /index.html
		file_server
	}
}

:8080 {
	import privatedao_primary_host
}

{$PRIMARY_DOMAIN:api.privatedao.org} {
	import privatedao_primary_host
}

privatedao.org, www.privatedao.org {
	import privatedao_primary_host
}
