{
  "name": "private-dao",
  "version": "0.3.0",
  "description": "Commit-reveal private voting for Solana DAOs — Graveyard Hackathon 2026",
  "scripts": {
    "build":             "anchor build",
    "test":              "anchor test",
    "typecheck":         "tsc --noEmit",
    "demo":              "anchor test --run tests/demo.ts",
    "test:core":         "anchor test --run tests/private-dao.ts",
    "test:full":         "anchor test --run tests/full-flow-test.ts",
    "deploy":            "anchor deploy --provider.cluster devnet",
    "setup":             "bash scripts/setup-devnet.sh",
    "check:contracts":   "bash scripts/check-contracts.sh",
    "localnet":          "solana-test-validator --reset",
    "create-dao":        "ts-node scripts/create-dao.ts",
    "create-proposal":   "ts-node scripts/create-proposal.ts",
    "deposit":           "ts-node scripts/deposit-treasury.ts",
    "list-proposals":    "ts-node scripts/list-proposals.ts",
    "delegate":          "ts-node scripts/delegate-vote.ts",
    "commit":            "ts-node scripts/commit-vote.ts",
    "reveal":            "ts-node scripts/reveal-vote.ts",
    "finalize":          "ts-node scripts/finalize.ts",
    "execute":           "ts-node scripts/execute.ts",
    "live-proof":        "ts-node scripts/live-devnet-proof.ts",
    "validate:ranger-strategy": "ts-node scripts/validate-ranger-strategy.ts",
    "build:ranger-submission": "ts-node scripts/build-ranger-submission.ts",
    "check:mainnet":     "bash scripts/check-mainnet-readiness.sh",
    "migrate":           "ts-node migrations/migrate-realms-dao.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js":   "^1.98.0",
    "@solana/spl-token": "^0.4.9",
    "dotenv":            "^16.4.5"
  },
  "devDependencies": {
    "@types/chai":  "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node":  "^20.0.0",
    "chai":         "^4.3.6",
    "mocha":        "^10.2.0",
    "ts-mocha":     "^10.0.0",
    "typescript":   "^5.0.0",
    "ts-node":      "^10.9.0"
  }
}
