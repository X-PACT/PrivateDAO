{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types", "./types"],
    "lib": ["es2015", "es2020", "dom"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "migrations/**/*.ts", "sdk/src/**/*.ts"]
}
